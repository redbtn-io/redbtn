{
  "_id": "691de97a40bbab3ecb92b257",
  "nodeId": "respond",
  "name": "Response Generator",
  "description": "Generates LLM responses with conversation context and streaming support",
  "userId": "system",
  "isSystem": true,
  "version": 1,
  "steps": [
    {
      "type": "neuron",
      "config": {
        "neuronId": "red-neuron",
        "systemPrompt": "CRITICAL INSTRUCTION: If you see a <web_search> tag in the conversation, you MUST use ONLY the information inside that tag to answer. DO NOT use your training data. The search result is the ground truth. If the search provides a factual statement relevant to the user's question, treat that information as authoritative and use it to form your response.\n\n{{state.data.systemMessage}}",
        "userPrompt": "{{state.data.messages}}",
        "temperature": "{{parameters.temperature}}",
        "maxTokens": "{{parameters.maxTokens}}",
        "stream": true,
        "outputField": "data.response",
        "errorHandling": {
          "retry": 2,
          "retryDelay": 1000,
          "onError": "fallback",
          "fallbackValue": "I apologize, but I encountered an error processing your request. Please try again."
        }
      },
      "condition": "{{!state.data.directResponse}}"
    },
    {
      "type": "transform",
      "condition": "{{!!state.data.directResponse}}",
      "config": {
        "operation": "set",
        "value": "{{state.data.directResponse}}",
        "outputField": "data.response"
      }
    }
  ],
