  "nodeId": "browse",
  "name": "Web Browser/Scraper",
  "description": "Fetches and extracts content from URLs using MCP scrape_url tool",
  "userId": "system",
  "isSystem": true,
  "version": 1,
  "steps": [
    {
      "type": "conditional",
      "config": {
        "condition": "true",
        "setField": "targetUrl",
        "trueValue": "{{toolParam}}",
        "falseValue": "{{query.message}}"
      }
    },
    {
      "type": "tool",
      "config": {
        "toolName": "scrape_url",
        "parameters": {
          "url": "{{targetUrl}}"
        },
        "outputField": "data.scrapedContent",
        "errorHandling": {
          "retry": 2,
          "retryDelay": 2000,
          "fallbackValue": "Error: Unable to fetch URL content",
          "onError": "fallback"
        }
      }
    },
    {
      "type": "conditional",
      "config": {
        "condition": "true",
        "setField": "nextGraph",
        "trueValue": "responder",
        "falseValue": ""
      }
    }
  ],
