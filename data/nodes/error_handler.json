  "_id": "69337af25cc62ee4ef6e5b6f",
  "nodeId": "error_handler",
  "description": "Handles system errors and provides user-friendly feedback",
  "isSystem": true,
  "name": "Global Error Handler",
  "steps": [
    {
      "type": "neuron",
      "config": {
        "neuronId": "red-neuron",
        "systemPrompt": "A system error has occurred during the execution of the user's request.\n\nYour job is to:\n1. Apologize to the user.\n2. Briefly explain that an internal error occurred.\n3. Provide the error details if they are safe to share.\n4. Suggest they try again or rephrase.\n\nBe helpful and concise.",
        "userPrompt": "Error Details: {{state.data.error}}\n\nOriginal Request: {{state.data.query.message}}",
        "outputField": "data.response",
        "stream": true,
        "temperature": "{{parameters.temperature}}",
        "maxTokens": 500
      }
    },
    {
      "type": "transform",
      "config": {
        "operation": "set",
        "value": "{{({ content: state.data.response })}}",
        "outputField": "data.response"
      }
    }
  ],
